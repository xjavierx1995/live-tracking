# ──────────────────────────────────────────────
# LIVE TRACKING - Variables de entorno raíz
# Copiar a .env y ajustar según necesidad
# ──────────────────────────────────────────────

# ── General ──────────────────────────────────
COMPOSE_PROJECT_NAME=live-tracking
APP_ENV=local

# ── MySQL ────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=live_tracking
MYSQL_PORT=3307

# ── Backend (Laravel) ────────────────────────
BACKEND_APP_URL=http://localhost
BACKEND_DB_HOST=mysql
BACKEND_DB_PORT=3306
BACKEND_DB_DATABASE=live_tracking
BACKEND_DB_USERNAME=root
BACKEND_DB_PASSWORD=root
BACKEND_TRACKING_SIMULATOR_BASE_URL=http://simulator:8001

# ── Tracking Simulator ───────────────────────
SIMULATOR_APP_URL=http://localhost:8001
SIMULATOR_DB_HOST=mysql
SIMULATOR_DB_PORT=3306
SIMULATOR_DB_DATABASE=live_tracking
SIMULATOR_DB_USERNAME=root
SIMULATOR_DB_PASSWORD=root
SIMULATOR_ORS_API_KEY=eyJvcmciOiI1YjNjZTM1OTc4NTExMTAwMDFjZjYyNDgiLCJpZCI6IjU3YzZjMjA0MDE1ZDRjOTk5OGI1N2Y2N2RmMjI2ZGVhIiwiaCI6Im11cm11cjY0In0=
SIMULATOR_ORS_BASE_URL=https://api.openrouteservice.org
SIMULATOR_SIMULATION_TICK_SECONDS=30
SIMULATOR_ROUTE_CENTER_LAT=4.7110
SIMULATOR_ROUTE_CENTER_LNG=-74.0721
SIMULATOR_ROUTE_RADIUS_METERS=5000

# ── Frontend ─────────────────────────────────
FRONTEND_PORT=5173
VITE_API_URL=http://localhost/api

# ── Nginx ────────────────────────────────────
NGINX_PORT=80